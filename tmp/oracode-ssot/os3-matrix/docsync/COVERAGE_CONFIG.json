{
  "_meta": {
    "version": "2.1.0",
    "purpose": "Configurazione soglie coverage DOC-SYNC v2.1.0 Coverage Native",
    "created": "2026-05-12",
    "author": "Padmin D. Curtis (AI Partner OS3.0) for Fabio Cherici",
    "applies_to": "rag_natan_coverage.py + cron docsync_weekly_reglob"
  },
  "thresholds": {
    "_default": 50.0,
    "EGI": 30.0,
    "EGI-DOC": 5.0,
    "YURI-BIAGINI": 0.0,
    "EGI-STAT": 30.0,
    "EGI-HUB-HOME-REACT": 30.0,
    "EGI-SALES": 30.0
  },
  "max_broken_patterns_pct": 25.0,
  "max_dead_ssots_pct": 5.0,
  "drift_alert_threshold": 0.5,
  "exclusions": [
    "^node_modules/", "/node_modules/", "^vendor/", "/vendor/",
    "\\.lock$", "composer\\.lock$", "package-lock\\.json$",
    "yarn\\.lock$", "pnpm-lock\\.yaml$",
    "\\.svg$", "\\.png$", "\\.jpe?g$", "\\.gif$", "\\.webp$", "\\.ico$",
    "\\.woff2?$", "\\.ttf$", "\\.otf$", "\\.eot$",
    "\\.mp4$", "\\.mov$", "\\.webm$", "\\.mp3$", "\\.wav$", "\\.ogg$",
    "\\.pdf$", "\\.zip$", "\\.tar(\\.gz)?$", "\\.gz$",
    "\\.docx?$", "\\.xlsx?$", "\\.pptx?$",
    ":Zone\\.Identifier$", "\\.~lock\\.", "\\.DS_Store$",
    "storage/framework/", "storage/logs/", "bootstrap/cache/",
    "^public/audio/", "^public/storage/",
    "^laravel_backend/public/audio/",
    "^dist/", "/dist/", "^build/", "/\\.next/", "^\\.next/"
  ]
}
